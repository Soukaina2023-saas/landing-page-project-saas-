    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.3",
    "node-fetch": "^2.7.0",
    "prisma": "^7.4.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20.19.33",
    "@types/supertest": "^6.0.3",
    "dotenv-cli": "^11.0.0",
    "supertest": "^7.2.2",
    "typescript": "^5.3.3",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": "20.x"
  },
  "keywords": [
